.page-container {
  padding: 12rpx 12rpx 180rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.1));
  animation: logoBounce 2s ease-in-out infinite;
}

@keyframes logoBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.85);
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.4);
}

/* 信息卡片 */
.info-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 10rpx 12rpx;
  width: calc(100% - 24rpx);
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
  animation: fadeUp 0.3s ease both;
}

.info-card:nth-child(2) { animation-delay: 0.1s; }
.info-card:nth-child(3) { animation-delay: 0.2s; }
.info-card:nth-child(4) { animation-delay: 0.3s; }

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.info-label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.5);
}

.info-value {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.8);
  text-align: right;
  max-width: 60%;
}

/* 作者区域 */
.author-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 8rpx 0;
}

.author-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891b2, #0284c7);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(8, 145, 178, 0.25);
}

.author-avatar.ai {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.25);
}

.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.85);
  display: block;
}

.author-role {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
  display: block;
  margin-top: 4rpx;
}

.author-model {
  font-size: 22rpx;
  color: rgba(99, 102, 241, 0.6);
  display: block;
  margin-top: 2rpx;
}

.divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 12rpx 0;
}

/* 技术栈 */
.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.7);
  display: block;
  margin-bottom: 16rpx;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tech-tag {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(8, 145, 178, 0.1);
  color: #0891b2;
  border: 1rpx solid rgba(8, 145, 178, 0.15);
}

/* 仓库地址 */
.repo-card {
  animation-delay: 0.35s;
}

.repo-card:active {
  transform: scale(0.98);
}

.repo-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.repo-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.repo-meta {
  flex: 1;
  min-width: 0;
}

.repo-label {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.7);
  display: block;
}

.repo-url {
  font-size: 24rpx;
  color: #0891b2;
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-hint {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.3);
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.04);
}

/* 底部 */
.footer {
  padding: 40rpx 0 60rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.25);
  margin-top: 4rpx;
}
