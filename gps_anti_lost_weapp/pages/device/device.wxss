.page-container {
  padding: 12rpx 12rpx 180rpx;
  min-height: 100vh;
}

.page-scroll {
  height: calc(100vh - 0rpx);
  padding-bottom: 40rpx;
}

/* 设备头部 */
.device-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  animation: fadeUp 0.3s ease;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.device-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891b2, #0284c7);
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(8, 145, 178, 0.3);
}

.device-name {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.85);
  display: block;
}

.status-row {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-dot.online { background: #059669; box-shadow: 0 0 8rpx rgba(5, 150, 105, 0.4); }
.status-dot.offline { background: #9ca3af; }

.status-txt { font-size: 24rpx; }
.status-txt.online { color: #16a34a; }
.status-txt.offline { color: rgba(0, 0, 0, 0.35); }

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: background 0.2s;
}

.refresh-btn:active {
  background: rgba(255, 255, 255, 0.55);
}

.refresh-txt {
  font-size: 22rpx;
}

/* 地图区域 */
.map-section {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  margin: 12rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  animation: fadeUp 0.3s ease 0.1s both;
}

.map-section.no-location {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.no-loc-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.08));
}

.no-loc-title {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.45);
  margin-bottom: 8rpx;
}

.no-loc-sub {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.25);
}

.map-tools {
  margin-top: 12rpx;
}

.map-coords {
  text-align: center;
  margin-bottom: 12rpx;
}

.coord-text {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.6);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.map-actions {
  display: flex;
  gap: 12rpx;
  justify-content: center;
}

.map-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s;
}

.map-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.7);
}

.map-btn.active {
  background: rgba(8, 145, 178, 0.15);
  border-color: rgba(8, 145, 178, 0.3);
}

.map-btn-label {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.6);
}

.map-btn.active .map-btn-label {
  color: #0891b2;
}

/* 属性卡片网格 */
.props-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  margin: 12rpx;
}

.prop-card {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s;
  animation: fadeUp 0.3s ease both;
}

.prop-card:active {
  transform: scale(0.95);
}

.prop-card.speed { border-top: 4rpx solid rgba(2, 132, 199, 0.5); animation-delay: 0.15s; }
.prop-card.type { border-top: 4rpx solid rgba(8, 145, 178, 0.5); animation-delay: 0.2s; }
.prop-card.satellite { border-top: 4rpx solid rgba(5, 150, 105, 0.5); animation-delay: 0.25s; }
.prop-card.lbs { border-top: 4rpx solid rgba(217, 119, 6, 0.5); animation-delay: 0.3s; }
.prop-card.wifi { border-top: 4rpx solid rgba(6, 182, 212, 0.5); animation-delay: 0.35s; }
.prop-card.interval { border-top: 4rpx solid rgba(239, 68, 68, 0.5); animation-delay: 0.4s; }

.prop-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.08));
}

.prop-value {
  font-size: 38rpx;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.85);
}

.prop-unit {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.4);
  margin-top: 2rpx;
}

.prop-label {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 6rpx;
  font-weight: 500;
}

/* 控制区域 */
.control-section {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  margin: 12rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  animation: fadeUp 0.3s ease 0.45s both;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.85);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.control-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.control-item + .control-item {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.control-label {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.8);
  display: block;
}

.control-desc {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.4);
  display: block;
  margin-top: 4rpx;
}

.switch-group {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
}

.switch-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: rgba(0, 0, 0, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  line-height: 1.5;
  transition: all 0.2s;
  min-width: 100rpx;
  text-align: center;
}

.switch-btn.active {
  background: rgba(8, 145, 178, 0.7);
  backdrop-filter: blur(12px);
  color: #ffffff;
  border-color: rgba(8, 145, 178, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.3);
}

.switch-btn:active {
  transform: scale(0.95);
}

.interval-selector {
  display: flex;
}

/* 操作按钮 */
.action-buttons {
  margin: 24rpx 12rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  animation: fadeUp 0.3s ease 0.55s both;
}

.btn-primary {
  background: linear-gradient(135deg, rgba(8, 145, 178, 0.85), rgba(2, 132, 199, 0.85));
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: white;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 18rpx;
  padding: 26rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(8, 145, 178, 0.25);
  transition: transform 0.2s;
}

.btn-primary:active {
  transform: scale(0.97);
}

.btn-edit {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: rgba(0, 0, 0, 0.75);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 18rpx;
  padding: 26rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.btn-edit:active {
  transform: scale(0.97);
  background: rgba(255, 255, 255, 0.7);
}

.btn-danger {
  background: rgba(239, 68, 68, 0.12);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.15);
  border-radius: 18rpx;
  padding: 26rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.btn-danger:active {
  transform: scale(0.97);
  background: rgba(239, 68, 68, 0.2);
}
