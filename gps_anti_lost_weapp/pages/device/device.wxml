<!-- 设备详情页 -->
<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading-spinner" wx:if="{{loading}}"></view>

  <view wx:else>
    <scroll-view scroll-y class="page-scroll">
    <!-- 设备头部 -->
    <view class="device-header">
      <view class="header-left">
        <view class="device-avatar">{{deviceAvatar}}</view>
        <view class="header-info">
          <text class="device-name">{{deviceName}}</text>
          <view class="status-row">
            <view class="status-dot {{online ? 'online' : 'offline'}}"></view>
            <text class="status-txt {{online ? 'online' : 'offline'}}">{{online ? '在线' : '离线'}}</text>
          </view>
        </view>
      </view>
      <view class="header-right">
        <view class="refresh-btn" bindtap="refreshDevice">
          <text>⟳</text>
          <text class="refresh-txt">刷新</text>
        </view>
      </view>
    </view>

    <!-- 地图区域 -->
    <view class="map-section" wx:if="{{location}}">
      <map
        id="map"
        longitude="{{location.lng}}"
        latitude="{{location.lat}}"
        scale="15"
        markers="{{markers}}"
        style="width: 100%; height: 480rpx; border-radius: 20rpx; overflow: hidden;"
        enable-satellite="{{satellite}}"
        show-location="{{false}}"
      ></map>
      <view class="map-tools">
        <view class="map-coords">
          <text class="coord-text">{{locationLatFormatted}}, {{locationLngFormatted}}</text>
        </view>
        <view class="map-actions">
          <view class="map-btn {{satellite ? 'active' : ''}}" bindtap="toggleSatellite">
            <text>🛰️</text>
            <text class="map-btn-label">{{satellite ? '地图' : '卫星'}}</text>
          </view>
          <view class="map-btn" bindtap="copyCoords">
            <text>📋</text>
            <text class="map-btn-label">复制</text>
          </view>
          <view class="map-btn" bindtap="openMap">
            <text>🗺️</text>
            <text class="map-btn-label">导航</text>
          </view>
        </view>
      </view>
    </view>
    <view class="map-section no-location" wx:else>
      <view class="no-loc-icon">📍</view>
      <text class="no-loc-title">暂无位置信息</text>
      <text class="no-loc-sub">设备上线后将自动上报位置</text>
    </view>

    <!-- 属性卡片网格 -->
    <view class="props-grid">
      <!-- 速度 -->
      <view class="prop-card speed">
        <view class="prop-icon">🚀</view>
        <text class="prop-value">{{speedFormatted}}</text>
        <text class="prop-unit">km/h</text>
        <text class="prop-label">速度</text>
      </view>

      <!-- 定位类型 -->
      <view class="prop-card type">
        <view class="prop-icon">📡</view>
        <text class="prop-value">{{locationType || '--'}}</text>
        <text class="prop-label">定位类型</text>
      </view>

      <!-- 卫星数 -->
      <view class="prop-card satellite">
        <view class="prop-icon">🛰️</view>
        <text class="prop-value">{{satellites !== null ? satellites : '--'}}</text>
        <text class="prop-unit">颗</text>
        <text class="prop-label">卫星</text>
      </view>

      <!-- 基站 -->
      <view class="prop-card lbs">
        <view class="prop-icon">📶</view>
        <text class="prop-value">{{lbsCount || 0}}</text>
        <text class="prop-unit">个</text>
        <text class="prop-label">基站</text>
      </view>

      <!-- WiFi -->
      <view class="prop-card wifi">
        <view class="prop-icon">📶</view>
        <text class="prop-value">{{wifiCount || 0}}</text>
        <text class="prop-unit">个</text>
        <text class="prop-label">WiFi</text>
      </view>

      <!-- 上报间隔 -->
      <view class="prop-card interval">
        <view class="prop-icon">⏱️</view>
        <text class="prop-value">{{reportIntervalFormatted}}</text>
        <text class="prop-unit">分钟</text>
        <text class="prop-label">上报间隔</text>
      </view>
    </view>

    <!-- 控制区域 -->
    <view class="control-section">
      <view class="section-title">远程控制</view>

      <!-- 定位模式切换 -->
      <view class="control-item">
        <view class="control-left">
          <text class="control-label">定位模式</text>
          <text class="control-desc">当前: {{locationMode || '默认(GPS+LBS)'}}</text>
        </view>
        <view class="switch-group">
          <button
            class="switch-btn {{locationModeValue === 0 ? 'active' : ''}}"
            bindtap="setLocationMode" data-mode="0"
          >默认</button>
          <button
            class="switch-btn {{locationModeValue === 1 ? 'active' : ''}}"
            bindtap="setLocationMode" data-mode="1"
          >纯LBS</button>
        </view>
      </view>

      <!-- 上报间隔调整 -->
      <view class="control-item">
        <view class="control-left">
          <text class="control-label">上报间隔</text>
          <text class="control-desc">当前: {{reportIntervalDesc}}</text>
        </view>
        <view class="interval-selector">
          <picker mode="selector" range="{{intervalOptions}}" bindchange="setInterval">
            <button class="switch-btn">修改</button>
          </picker>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="btn-primary" bindtap="viewHistory">📊 查看历史数据</view>
      <view class="btn-edit" bindtap="editDevice">✏️ 编辑设备配置</view>
      <view class="btn-danger" bindtap="deleteDevice">🗑️ 删除设备</view>
      <view style="height:40rpx"></view>
    </view>
    </scroll-view>
  </view>
</view>
