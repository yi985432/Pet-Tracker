.page-container {
  padding: 12rpx;
  min-height: 100vh;
}

/* 属性选择器 */
.selector-bar {
  display: flex;
  gap: 12rpx;
  margin: 12rpx;
  overflow-x: auto;
  padding: 4rpx 12rpx 12rpx;
  -webkit-overflow-scrolling: touch;
}

.selector-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.6);
  white-space: nowrap;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.selector-item:active {
  transform: scale(0.95);
}

.selector-item.active {
  background: rgba(8, 145, 178, 0.7);
  backdrop-filter: blur(16px);
  color: #ffffff;
  border-color: rgba(8, 145, 178, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(8, 145, 178, 0.25);
}

.selector-icon {
  font-size: 30rpx;
}

/* 时间范围 */
.time-bar {
  display: flex;
  gap: 8rpx;
  margin: 0 12rpx 12rpx;
}

.time-item {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.55);
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.time-item:active {
  transform: scale(0.95);
}

.time-item.active {
  background: rgba(8, 145, 178, 0.7);
  backdrop-filter: blur(12px);
  color: #ffffff;
  border-color: rgba(8, 145, 178, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.2);
}

/* 图表区域 */
.chart-section {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  margin: 12rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  animation: fadeUp 0.3s ease;
  position: relative;
  min-height: 300rpx;
}

/* 图表加载浮层 */
.chart-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(4px);
  border-radius: 24rpx;
  z-index: 2;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.85);
}

.chart-count {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.4);
}

.chart-canvas {
  width: 100%;
  height: 500rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.02);
}

/* 数据概览 */
.data-summary {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}

.summary-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #0891b2;
}

/* 数据列表 */
.data-list {
  margin-top: 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.data-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.data-time {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}

.data-value {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.8);
}

.empty-state {
  text-align: center;
  padding: 60rpx;
  color: rgba(0, 0, 0, 0.35);
  font-size: 28rpx;
}

/* 轨迹地图 */
.map-wrap {
  position: relative;
}

.track-info {
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
  padding: 8rpx 0 16rpx;
}
