.page-container {
  padding: 0rpx 0rpx 180rpx;
  min-height: 100vh;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.85);
  margin: 16rpx 24rpx;
  padding: 24rpx 0 16rpx;
}

/* 设备列表 */
.device-item {
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  margin: 10rpx 24rpx;
  padding: 48rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
  animation: fadeUp 0.3s ease both;
}

.device-item:active {
  transform: scale(0.98);
}

.device-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.device-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.device-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891b2, #0284c7);
  color: white;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(8, 145, 178, 0.25);
}

.device-meta {
  flex: 1;
  min-width: 0;
}

.device-name {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.85);
  display: block;
  line-height: 1.4;
}

.device-product {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.device-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 14rpx 28rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  line-height: 1.5;
  transition: transform 0.2s;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.action-btn:active {
  transform: scale(0.92);
}

.action-btn.edit {
  background: rgba(8, 145, 178, 0.12);
  color: #0891b2;
}

.action-btn.delete {
  background: rgba(239, 68, 68, 0.12);
  color: #ef4444;
}

/* 添加按钮 */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin: 20rpx 24rpx;
  padding: 40rpx;
  border: 1rpx dashed rgba(255, 255, 255, 0.5);
  border-radius: 24rpx;
  color: rgba(0, 0, 0, 0.45);
  font-size: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: all 0.2s;
}

.add-btn:active {
  background: rgba(255, 255, 255, 0.35);
  transform: scale(0.98);
}

/* 表单滚动容器 */
.form-scroll {
  height: calc(100vh - 200rpx);
  padding-bottom: 120rpx;
}

/* 帮助信息 */
.help-section {
  background: rgba(59, 130, 246, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  margin: 16rpx 24rpx;
  padding: 36rpx 32rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.15);
}

.help-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e40af;
  margin-bottom: 12rpx;
}

.help-content text {
  display: block;
  font-size: 24rpx;
  color: #3b82f6;
  line-height: 1.8;
}

/* 表单 */
.form-section {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  margin: 12rpx 24rpx;
  padding: 36rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
  animation: fadeUp 0.3s ease;
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.85);
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.75);
  display: block;
  margin-bottom: 8rpx;
}

.input-field {
  width: 100%;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(0, 0, 0, 0.8);
  box-sizing: border-box;
  min-height: 88rpx;
}

.input-field:focus {
  border-color: rgba(79, 70, 229, 0.4);
  background: rgba(255, 255, 255, 0.7);
}

.form-hint {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-top: 6rpx;
}

.form-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, rgba(8, 145, 178, 0.85), rgba(2, 132, 199, 0.85));
  backdrop-filter: blur(12px);
  color: white;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 18rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(8, 145, 178, 0.2);
}

.btn-cancel {
  flex: 1;
  background: rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(8px);
  color: rgba(0, 0, 0, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 18rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  transform: scale(0.97);
}

.btn-cancel:active {
  background: rgba(0, 0, 0, 0.1);
  transform: scale(0.97);
}

/* Token 帮助 */
.token-help {
  background: rgba(234, 179, 8, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  margin: 12rpx 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(234, 179, 8, 0.15);
}

.token-help-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #a16207;
  margin-bottom: 12rpx;
}

.token-help-content text {
  display: block;
  font-size: 24rpx;
  color: #ca8a04;
  line-height: 1.8;
}

.mt-8 {
  margin-top: 8rpx;
}
