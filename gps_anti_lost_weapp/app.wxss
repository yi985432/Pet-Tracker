/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  background: linear-gradient(150deg, #f0f9ff 0%, #e0f2fe 30%, #fdf2f8 70%, #fef3c7 100%) fixed;
  color: #333;
  min-height: 100vh;
}

/* 玻璃卡片通用样式 */
.glass-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05), inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

/* 玻璃按钮 */
.glass-btn {
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.glass-btn:active {
  background: rgba(255, 255, 255, 0.55);
}

/* 卡片组件 */
.card {
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  margin: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

/* 强调色：青蓝 */
.accent-cyan { color: #0891b2; }
.accent-sky { color: #0284c7; }
/* 强调色：暖橙 */
.accent-amber { color: #d97706; }
/* 成功/在线 */
.accent-green { color: #059669; }

/* 状态指示器 */
.status-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.status-dot.online { background-color: #22c55e; }
.status-dot.offline { background-color: #9ca3af; }

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-danger {
  background: #ef4444;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-danger:active {
  opacity: 0.8;
}

/* 输入框 */
.input-field {
  width: 100%;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #4f46e5;
  outline: none;
}

/* 加载动画 */
.loading-spinner {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx;
}

.loading-spinner::after {
  content: '';
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid rgba(79, 70, 229, 0.15);
  border-top-color: #4f46e5;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  box-shadow: 0 0 20rpx rgba(79, 70, 229, 0.05);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: #9ca3af;
}

.empty-state text {
  font-size: 28rpx;
  margin-top: 16rpx;
}
